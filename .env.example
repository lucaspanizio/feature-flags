# Copie este arquivo para ".env" e ajuste os valores antes de subir o docker compose.
# Nunca faça commit do arquivo ".env" (já está no .gitignore).

# ---- Postgres ----
DATABASE_NAME=unleash
DATABASE_USERNAME=unleash_user
DATABASE_PASSWORD=troque-esta-senha

# ---- Unleash ----
UNLEASH_PORT=4242
UNLEASH_VERSION=latest
UNLEASH_URL=http://localhost:4242
LOG_LEVEL=warn

# Credenciais do admin criado na primeira inicialização (troque a senha pela UI no primeiro login)
UNLEASH_ADMIN_USERNAME=admin
UNLEASH_ADMIN_PASSWORD=troque-esta-senha-tambem

# Origens do navegador autorizadas a chamar a Frontend API (app React). Separe por vírgula.
# Vite pode subir em 5173 ou na porta seguinte livre (5174, 5175...) se já houver outro dev
# server rodando — adicione as portas extras aqui se aparecer erro de CORS.
UNLEASH_FRONTEND_API_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# Tokens de bootstrap, criados apenas na primeira inicialização do banco.
# Formato: <projeto>:<ambiente>.<segredo>
# Os valores abaixo são os "insecure" de exemplo da própria Unleash — troque-os
# antes de expor o serviço fora da sua máquina/rede local. Depois do primeiro boot,
# prefira criar tokens definitivos pela Admin UI (Settings > API access).
INIT_BACKEND_API_TOKENS=default:development.unleash-insecure-api-token
INIT_FRONTEND_API_TOKENS=default:development.unleash-insecure-frontend-api-token

# ---- App React (Vite) ----
VITE_UNLEASH_URL=http://localhost:4242
VITE_UNLEASH_FRONTEND_TOKEN=<TOKEN_DE_FRONTEND_ACIMA>
